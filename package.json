{
  "name": "@inference-gateway/infer-action",
  "version": "0.31.3",
  "private": true,
  "type": "module",
  "description": "TypeScript hot-path scripts for the Infer Agent GitHub Action",
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "bundle": "bun run format:write && bun run package",
    "build:prompts": "bun scripts/build-prompts.mjs",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "generate": "bun scripts/gen-providers.mjs && bun run format:write",
    "lint": "bun run build:prompts && eslint .",
    "lint:md": "markdownlint . --ignore '{CHANGELOG,AGENTS,CLAUDE}.md'",
    "package": "bun run build:prompts && bun scripts/bundle.mjs",
    "test": "bun run build:prompts && bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run build:prompts && tsc --noEmit",
    "all": "bun run format:write && bun run lint && bun run typecheck && bun run test && bun run package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
